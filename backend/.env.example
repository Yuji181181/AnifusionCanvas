# Database (TiDB Serverless)
DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:4000/DB_NAME

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_ENDPOINT_URL=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_REGION=auto

# Hugging Face / model artifacts
HF_TOKEN=
MODEL_CACHE_DIR=./artifacts/models
TOONCRAFTER_MODEL_ID=
SD_INPAINT_MODEL_ID=

# Modal integration
MODAL_PROFILE=default
MODAL_APP_NAME=anifusion-canvas

# Optional GPU inference endpoint settings
MODAL_ENDPOINT=
